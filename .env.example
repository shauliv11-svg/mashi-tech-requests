NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Do not expose this as NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-only email sending through Gmail/Google Workspace SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-google-app-password
EMAIL_FROM=בקשות טכנולוגיה משי <your-sender@gmail.com>
EMAIL_REPLY_TO=your-reply-address@example.com
